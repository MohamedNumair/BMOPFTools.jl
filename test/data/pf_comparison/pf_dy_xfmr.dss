! Delta-wye (Dy) three-phase transformer power-flow comparison case.
! (BMOPF subtype: delta_wye)
!
! Topology: hv ──[Dy xfmr, 11 kV delta / 0.415 kV wye]── lv
!   hv.1/2/3    = HV delta terminals (no neutral on delta bus)
!   lv.1/2/3/4  = LV wye phases and neutral
!
! Unbalanced wye-to-neutral loads on the LV side produce measurable neutral
! displacement. The neutral earthing reactor (0.3 Ω) becomes a BMOPF shunt,
! matching the LV1_14bus convention.  Any error in the Dy constraint or the
! angle reference will appear as non-zero slack or voltage mismatch.

Clear

New Circuit.pf_dy_xfmr basekv=11.0 pu=1.0 angle=0 phases=3 bus1=hv.1.2.3

! 2-winding DELTA-WYE → PMD classifies as 'delta_wye'.
! %r=0.1 xhl=0.1 → voltage drop < 0.2 V; within the 1 V BMOPF tolerance
! for the ideal-transformer model that ignores series impedance.
New Transformer.t1 phases=3 windings=2
~ wdg=1 bus=hv.1.2.3   conn=delta kv=11.0  %r=0.1 kva=500
~ wdg=2 bus=lv.1.2.3.4 conn=wye   kv=0.415 %r=0.1 kva=500
~ xhl=0.1

! LV neutral earthed via 0.3 Ω reactor (matches LV1_14bus convention).
New Reactor.grnd_lv bus1=lv.4 bus2=lv.0 R=0.3 X=0

! Unbalanced constant-power wye-to-neutral loads (kv = 0.415/√3 ≈ 0.240 kV).
! Vminpu=0 Vmaxpu=2: disable ODS voltage-dependent load switching so model=1
! behaves as strict constant P+Q at all voltages, matching BMOPF.
New Load.ld1 bus1=lv.1.4 kv=0.240 kw=100 kvar=30  phases=1 model=1 Vminpu=0 Vmaxpu=2
New Load.ld2 bus1=lv.2.4 kv=0.240 kw=80  kvar=25  phases=1 model=1 Vminpu=0 Vmaxpu=2
New Load.ld3 bus1=lv.3.4 kv=0.240 kw=120 kvar=40  phases=1 model=1 Vminpu=0 Vmaxpu=2

Set VoltageBases=[11.0, 0.415]
CalcVoltageBases
Solve
